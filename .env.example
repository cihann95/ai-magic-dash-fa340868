# =============================================================================
# Lumen Trade — Environment Variable Template
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control — it contains secrets.
# =============================================================================

# -- Node Environment --------------------------------------------------------
NODE_ENV=development

# -- Frontend (Vite) ---------------------------------------------------------
# These are exposed to the browser via import.meta.env.VITE_*
# NEVER put secrets here — only public/safe values.
VITE_SUPABASE_URL=https://xynpcusbbjfoyphtfcgz.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_ANA_SAHNE_ENABLED=true

# VAPID (Web Push)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Sentry (frontend DSN, optional)
VITE_SENTRY_DSN=your_sentry_dsn

# -- Edge Functions (Deno / Supabase) ----------------------------------------
# These are set via Supabase Dashboard → Edge Functions → Environment Variables
SUPABASE_URL=https://xynpcusbbjfoyphtfcgz.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key
OPENROUTER_API_KEY=your_openrouter_api_key

# -- Upstash Redis (optional, fail-open) -------------------------------------
UPSTASH_REDIS_REST_URL=https://your-upstash-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# -- Web Push VAPID Keys (optional, required for push notifications) ----------
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:your-email@domain.com

# -- Observability -----------------------------------------------------------
SENTRY_DSN=https://your-sentry-dsn@sentry.example.com/project-id
LOG_LEVEL=info
